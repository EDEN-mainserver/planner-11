# PlanForge 환경 변수
# 이 파일을 복사해서 .env 로 만들고 본인 키를 입력하세요

# ──────────────────────────────────────
# 웹 UI (web/planforge-ui/.env 에 넣어야 함)
# ──────────────────────────────────────

# Google Gemini API (필수 — Vite 프론트엔드용)
VITE_GEMINI_API_KEY=여기에_본인_Gemini_API_키_입력

# ──────────────────────────────────────
# 백엔드 Python 엔진 (루트 .env 에 넣어야 함)
# ──────────────────────────────────────

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT 폴백용)
OPENAI_API_KEY=sk-xxxxx

# Google Sheets (로그 기록용)
GOOGLE_SHEETS_CREDENTIALS_PATH=./config/google_credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=xxxxx

# Slack (알림용)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx
