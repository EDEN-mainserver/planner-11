{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "planforge://schemas/flow.schema.json",
  "title": "User Flow (유저 플로우)",
  "description": "PRD의 scenarios/features와 연결되며, 에덴 에이전트가 자동화 파이프라인의 실행 순서와 분기 로직을 파악하는 문서.",
  "type": "object",
  "required": ["meta", "flows"],
  "properties": {

    "meta": {
      "type": "object",
      "required": ["project_id", "prd_version", "created_at"],
      "properties": {
        "project_id": {
          "type": "string",
          "pattern": "^PRJ-[0-9]{4}-[0-9]{3}$"
        },
        "prd_version": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "flows": {
      "type": "array",
      "description": "유저 플로우 목록 (시나리오별 1개)",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["flow_id", "title", "nodes", "edges"],
        "properties": {

          "flow_id": {
            "type": "string",
            "pattern": "^FLOW-[0-9]{3}$",
            "examples": ["FLOW-001"]
          },

          "title": {
            "type": "string",
            "description": "플로우 제목",
            "examples": ["신규 가격 문의 자동 응대 플로우"]
          },

          "linked_scenario_id": {
            "type": "string",
            "description": "PRD scenario ID 참조",
            "examples": ["SC-001"]
          },

          "description": {
            "type": "string",
            "description": "플로우 요약 설명"
          },

          "actor": {
            "type": "string",
            "description": "플로우 주체",
            "examples": ["시스템", "크몽 구매자", "담당자"]
          },

          "nodes": {
            "type": "array",
            "description": "플로우 노드 (화면, 액션, 판단, 시작/끝)",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["node_id", "type", "label"],
              "properties": {

                "node_id": {
                  "type": "string",
                  "pattern": "^N-[0-9]{3}$",
                  "examples": ["N-001"]
                },

                "type": {
                  "type": "string",
                  "enum": [
                    "start",
                    "end",
                    "action",
                    "decision",
                    "subprocess",
                    "wait",
                    "human_input",
                    "error"
                  ],
                  "description": "노드 유형: start/end(터미널), action(실행), decision(분기), subprocess(하위 플로우 호출), wait(대기), human_input(사람 개입), error(에러 처리)"
                },

                "label": {
                  "type": "string",
                  "description": "노드에 표시되는 텍스트",
                  "examples": ["문의 유형 분류", "가격 문의인가?", "응답 메시지 발송"]
                },

                "description": {
                  "type": "string",
                  "description": "노드 상세 설명 (에이전트가 구현 시 참고)"
                },

                "linked_spec_id": {
                  "type": "string",
                  "description": "이 노드를 구현하는 기능명세서 ID",
                  "examples": ["SPEC-002"]
                },

                "linked_action_id": {
                  "type": "string",
                  "description": "PRD automation_context.actions의 ID",
                  "examples": ["ACT-002"]
                },

                "executor": {
                  "type": "string",
                  "enum": ["system", "ai", "human"],
                  "description": "실행 주체: 시스템 자동/AI 판단/사람 개입",
                  "default": "system"
                },

                "estimated_duration": {
                  "type": "string",
                  "description": "예상 소요 시간",
                  "examples": ["즉시", "5초", "5분", "담당자 응답 대기"]
                },

                "data_snapshot": {
                  "type": "object",
                  "description": "이 노드 시점에서의 데이터 상태",
                  "properties": {
                    "available_data": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "이 시점에서 사용 가능한 데이터 필드",
                      "examples": [["message_id", "sender_name", "message_content"]]
                    },
                    "new_data": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "이 노드에서 새로 생성되는 데이터",
                      "examples": [["inquiry_type", "confidence_score"]]
                    }
                  }
                }
              }
            }
          },

          "edges": {
            "type": "array",
            "description": "노드 간 연결선",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["from", "to"],
              "properties": {

                "from": {
                  "type": "string",
                  "description": "출발 노드 ID",
                  "examples": ["N-003"]
                },

                "to": {
                  "type": "string",
                  "description": "도착 노드 ID",
                  "examples": ["N-004"]
                },

                "label": {
                  "type": "string",
                  "description": "연결선 라벨 (분기 조건 등)",
                  "examples": ["Yes: 가격 문의", "No: 커스텀 상담", "성공", "실패", "timeout"]
                },

                "condition": {
                  "type": "object",
                  "description": "★ 분기 조건 상세 — 에이전트가 if/else 로직을 짤 때 직접 참조",
                  "properties": {
                    "field": {
                      "type": "string",
                      "description": "판단 기준 필드",
                      "examples": ["inquiry_type", "confidence_score", "sent_status"]
                    },
                    "operator": {
                      "type": "string",
                      "enum": ["equals", "not_equals", "contains", "greater_than", "less_than", "in", "not_in", "exists", "not_exists"],
                      "description": "비교 연산자"
                    },
                    "value": {
                      "description": "비교 값 (타입 자유)",
                      "examples": ["price_inquiry", 0.8, true, ["price_inquiry", "timeline"]]
                    }
                  }
                },

                "is_error_path": {
                  "type": "boolean",
                  "description": "에러/예외 경로 여부",
                  "default": false
                }
              }
            }
          },

          "error_flows": {
            "type": "array",
            "description": "예외 처리 경로 (메인 플로우에서 분기)",
            "items": {
              "type": "object",
              "required": ["trigger_node_id", "error_type", "handling_node_id"],
              "properties": {
                "trigger_node_id": {
                  "type": "string",
                  "description": "에러 발생 노드"
                },
                "error_type": {
                  "type": "string",
                  "examples": ["auth_failure", "timeout", "data_not_found", "validation_error"]
                },
                "handling_node_id": {
                  "type": "string",
                  "description": "에러 처리 노드"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          },

          "mermaid": {
            "type": "string",
            "description": "사람용 Mermaid 다이어그램 코드 (human/ 출력에 사용)",
            "examples": ["flowchart TD\n  N001((시작)) --> N002[문의 감지]\n  N002 --> N003{유형 분류}\n  N003 -->|가격문의| N004[응답 생성]\n  N003 -->|커스텀| N005[담당자 알림]"]
          }
        }
      }
    }
  }
}
