  "constraints": {
    "assumptions": [
      "클라이언트가 크몽 로그인 정보를 안전하게 제공",
      "크몽 UI 구조가 대폭 변경되지 않음",
      "하루 문의량이 100건을 초과하지 않음"
    ],
    "technical_constraints": [
      "크몽 공식 API 미제공 → Playwright 브라우저 자동화 필수",
      "크몽 세션 만료 주기 약 2시간 → 세션 갱신 로직 필요",
      "LLM API 호출 비용 → 월 예상 비용 산출 필요"
    ],
    "business_constraints": [
      "구축 기간: 2주 이내",
      "월 운영 비용: 20만원 이내",
      "클라이언트가 기술 비전문가 → 관리 UI 최소화"
    ]
  },

