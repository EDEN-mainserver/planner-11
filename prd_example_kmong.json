  "automation_context": {
    "target_systems": [
      {
        "name": "크몽",
        "type": "web_app",
        "access_method": "browser_automation",
        "auth_required": true,
        "notes": "공식 API 미제공. Playwright 기반 브라우저 자동화 필요. 로그인 세션 유지 관리 필수."
      },
      {
        "name": "Google Sheets",
        "type": "spreadsheet",
        "access_method": "api",
        "auth_required": true,
        "notes": "Google Sheets API v4 사용. 서비스 계정 인증."
      },
      {
        "name": "카카오톡 알림톡",
        "type": "messenger",
        "access_method": "api",
        "auth_required": true,
        "notes": "비즈니스 채널 필요. 대안: 슬랙 webhook"
      }
    ],

    "triggers": [
      {
        "id": "TRG-001",
        "event": "새 문의 메시지 수신",
        "source": "크몽 메시지함",
        "condition": "읽지 않은 메시지 AND 내가 보낸 메시지가 아닌 것"
      },
      {
        "id": "TRG-002",
        "event": "스케줄 기반 체크",
        "source": "시스템 크론",
        "condition": "매 5분마다 크몽 메시지함 확인"
      }
    ],

    "actions": [
      {
        "id": "ACT-001",
        "order": 1,
        "action_type": "scrape",
        "description": "크몽 메시지함에서 읽지 않은 문의 메시지 수집",
        "target_system": "크몽",
        "input_fields": [
          { "name": "session_cookie", "type": "string", "required": true, "source": "auth_manager" }
        ],
        "output_fields": [
          { "name": "message_id", "type": "string" },
          { "name": "sender_name", "type": "string" },
          { "name": "message_content", "type": "string" },
          { "name": "received_at", "type": "date" }
        ],
        "trigger_id": "TRG-002",
        "depends_on": []
      },
      {
        "id": "ACT-002",
        "order": 2,
        "action_type": "decision",
        "description": "AI로 문의 내용 분석 → 유형 분류 (price_inquiry / timeline / revision / custom_consultation / other)",
        "target_system": "LLM API",
        "input_fields": [
          { "name": "message_content", "type": "string", "required": true, "source": "ACT-001.output" }
        ],
        "output_fields": [
          { "name": "inquiry_type", "type": "string" },
          { "name": "confidence_score", "type": "number" },
          { "name": "extracted_keywords", "type": "array" }
        ],
        "depends_on": ["ACT-001"]
      },
      {
        "id": "ACT-003",
        "order": 3,
        "action_type": "generate_content",
        "description": "분류된 유형에 맞는 응답 메시지 생성 (템플릿 + AI 맞춤)",
        "target_system": "LLM API",
        "input_fields": [
          { "name": "inquiry_type", "type": "string", "required": true, "source": "ACT-002.output" },
          { "name": "message_content", "type": "string", "required": true, "source": "ACT-001.output" },
          { "name": "service_info", "type": "json", "required": true, "source": "config.service_catalog" }
        ],
        "output_fields": [
          { "name": "response_message", "type": "string" },
          { "name": "include_price", "type": "boolean" }
        ],
        "depends_on": ["ACT-002"]
      },
      {
        "id": "ACT-004",
        "order": 4,
        "action_type": "data_write",
        "description": "생성된 응답 메시지를 크몽 메시지로 자동 발송",
        "target_system": "크몽",
        "input_fields": [
          { "name": "message_id", "type": "string", "required": true, "source": "ACT-001.output" },
          { "name": "response_message", "type": "string", "required": true, "source": "ACT-003.output" }
        ],
        "output_fields": [
          { "name": "sent_status", "type": "boolean" },
          { "name": "sent_at", "type": "date" }
        ],
        "depends_on": ["ACT-003"]
      },
      {
        "id": "ACT-005",
        "order": 5,
        "action_type": "notify",
        "description": "커스텀 상담 필요 시 담당자에게 알림 발송",
        "target_system": "카카오톡 알림톡",
        "input_fields": [
          { "name": "inquiry_type", "type": "string", "required": true, "source": "ACT-002.output" },
          { "name": "message_content", "type": "string", "required": true, "source": "ACT-001.output" },
          { "name": "sender_name", "type": "string", "required": true, "source": "ACT-001.output" }
        ],
        "output_fields": [
          { "name": "notification_sent", "type": "boolean" }
        ],
        "depends_on": ["ACT-002"]
      },
      {
        "id": "ACT-006",
        "order": 6,
        "action_type": "data_write",
        "description": "응대 내역을 구글 시트에 로그 기록",
        "target_system": "Google Sheets",
        "input_fields": [
          { "name": "message_id", "type": "string", "required": true, "source": "ACT-001.output" },
          { "name": "sender_name", "type": "string", "required": true, "source": "ACT-001.output" },
          { "name": "inquiry_type", "type": "string", "required": true, "source": "ACT-002.output" },
          { "name": "response_message", "type": "string", "required": true, "source": "ACT-003.output" },
          { "name": "sent_status", "type": "boolean", "required": true, "source": "ACT-004.output" }
        ],
        "output_fields": [
          { "name": "row_number", "type": "number" }
        ],
        "depends_on": ["ACT-004"]
      }
    ],

    "error_handling": [
      {
        "error_type": "auth_failure",
        "target_action_id": "ACT-001",
        "handling": "retry",
        "retry_count": 3,
        "fallback_action": "세션 재로그인 시도 후 실패 시 담당자에게 알림"
      },
      {
        "error_type": "timeout",
        "target_action_id": "ACT-001",
        "handling": "retry",
        "retry_count": 2,
        "fallback_action": "5분 후 재시도"
      },
      {
        "error_type": "validation_error",
        "target_action_id": "ACT-003",
        "handling": "notify_human",
        "fallback_action": "생성된 응답이 품질 기준 미달 시 담당자에게 원문 전달"
      },
      {
        "error_type": "rate_limit",
        "target_action_id": "ACT-004",
        "handling": "wait",
        "fallback_action": "60초 대기 후 재시도"
      }
    ],

    "data_flow": [
      {
        "field_name": "문의내용",
        "type": "string",
        "source": "크몽 메시지함 (ACT-001)",
        "destination": "AI 분류기 (ACT-002) → 응답 생성기 (ACT-003)",
        "transform": "없음 (원본 유지)"
      },
      {
        "field_name": "문의유형",
        "type": "string",
        "source": "AI 분류기 (ACT-002)",
        "destination": "응답 생성기 (ACT-003) / 알림 (ACT-005) / 로그 (ACT-006)",
        "transform": "enum 값으로 정규화"
      },
      {
        "field_name": "응답메시지",
        "type": "string",
        "source": "응답 생성기 (ACT-003)",
        "destination": "크몽 발송 (ACT-004) / 로그 (ACT-006)",
        "transform": "없음"
      }
    ]
  },

