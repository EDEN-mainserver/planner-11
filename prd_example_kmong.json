  "overview": {
    "category": "고객관리/CS",
    "one_liner": "크몽 문의 자동 감지 및 맞춤 응대 시스템",
    "background": "클라이언트는 크몽에서 디자인 서비스를 판매 중이며, 하루 평균 30건의 문의가 들어오나 수동으로 응대하여 평균 응답 시간이 4시간을 초과함.",
    "problem": "문의 응대 지연으로 전환율이 낮고, 반복적인 질문(가격, 작업기간, 수정횟수)에 매번 동일한 답변을 수동 작성해야 함.",
    "solution": "크몽 문의를 자동 감지하고, 문의 유형을 분류하여 사전 정의된 템플릿 기반 자동 응답을 발송. 복잡한 문의는 담당자에게 알림.",
    "differentiator": "단순 자동응답이 아닌, 문의 내용을 AI로 분석하여 맥락에 맞는 맞춤 응대를 생성하고 견적까지 자동 산출."
  },

  "target_users": [
    {
      "role": "크몽 판매자 (클라이언트)",
      "description": "크몽에서 서비스를 판매하며 문의 응대에 하루 2시간 이상을 소모하는 프리랜서/소규모 팀",
      "goals": [
        "문의 응답 시간을 5분 이내로 단축",
        "반복 문의에 대한 수동 작업 제거",
        "전환율 향상"
      ],
      "pain_points": [
        "같은 질문에 매번 복붙 응답",
        "바쁠 때 문의 놓치면 고객 이탈",
        "견적 산출에 시간 소모"
      ]
    }
  ],

  "scenarios": [
    {
      "id": "SC-001",
      "title": "신규 가격 문의 자동 응대",
      "actor": "크몽 구매자",
      "precondition": "시스템이 크몽 계정에 로그인된 상태",
      "steps": [
        { "order": 1, "action": "구매자가 크몽 메시지로 '로고 디자인 얼마예요?' 문의 발송", "expected_result": "메시지 수신 감지" },
        { "order": 2, "action": "시스템이 문의 내용을 AI로 분석하여 '가격 문의' 유형으로 분류", "expected_result": "유형: price_inquiry" },
        { "order": 3, "action": "해당 유형의 응답 템플릿 + 서비스 가격표 기반 맞춤 메시지 생성", "expected_result": "응답 메시지 초안 생성" },
        { "order": 4, "action": "생성된 메시지를 크몽 메시지로 자동 발송", "expected_result": "구매자에게 응답 도달" },
        { "order": 5, "action": "응대 로그를 스프레드시트에 기록", "expected_result": "날짜, 문의유형, 응답내용 저장" }
      ],
      "postcondition": "구매자가 5분 이내에 맞춤 응답을 받음"
    },
    {
      "id": "SC-002",
      "title": "복잡한 커스텀 문의 → 담당자 알림",
      "actor": "크몽 구매자",
      "precondition": "시스템이 크몽 계정에 로그인된 상태",
      "steps": [
        { "order": 1, "action": "구매자가 복잡한 요구사항 (레퍼런스 이미지 포함) 문의", "expected_result": "메시지 수신 감지" },
        { "order": 2, "action": "AI가 문의를 분석하여 '커스텀 상담 필요'로 분류", "expected_result": "유형: custom_consultation" },
        { "order": 3, "action": "접수 확인 자동 응답 발송 + 담당자에게 카톡/슬랙 알림", "expected_result": "구매자에게 '확인 중' 메시지, 담당자에게 알림" },
        { "order": 4, "action": "담당자가 직접 응대", "expected_result": "수동 개입" }
      ],
      "postcondition": "구매자가 접수 확인을 즉시 받고, 담당자가 30분 이내 응대"
    }
  ],

