{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/parse-pdf.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/image-generate.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/gemini.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/threads-crawl.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/x-crawl.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/x-trends.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/full-auto-run.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/full-auto-cron.js": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/full-auto-cron",
      "schedule": "0 * * * *"
    }
  ]
}
