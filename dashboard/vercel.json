{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/voices",         "destination": "/api/tts?_fn=voices" },
    { "source": "/api/naver-blog-crawl", "destination": "/api/naver?_fn=blog-crawl" },
    { "source": "/api/naver-datalab",  "destination": "/api/naver?_fn=datalab" },
    { "source": "/api/full-auto-run",  "destination": "/api/full-auto?_fn=run" },
    { "source": "/api/full-auto-config", "destination": "/api/full-auto?_fn=config" },
    { "source": "/api/instagram-post", "destination": "/api/social-post?_fn=instagram" },
    { "source": "/api/threads-post",   "destination": "/api/social-post?_fn=threads" },
    { "source": "/api/iboss-post",     "destination": "/api/social-post?_fn=iboss" },
    { "source": "/api/gif-proxy",      "destination": "/api/media?_fn=gif-proxy" },
    { "source": "/api/html-screenshot", "destination": "/api/media?_fn=screenshot" },
    { "source": "/api/crawl-url",      "destination": "/api/media?_fn=crawl" },
    { "source": "/((?!api/).*)",       "destination": "/index.html" }
  ],
  "functions": {
    "api/parse-pdf.js":    { "maxDuration": 60,  "memory": 1024 },
    "api/image-generate.js": { "maxDuration": 60,  "memory": 1024 },
    "api/gemini.js":       { "maxDuration": 60,  "memory": 1024 },
    "api/tts.js":          { "maxDuration": 60,  "memory": 1024 },
    "api/full-auto.js":    { "maxDuration": 300, "memory": 1024 },
    "api/full-auto-cron.js": { "maxDuration": 300, "memory": 1024 },
    "api/social-post.js":  { "maxDuration": 120, "memory": 1024 },
    "api/media.js":        { "maxDuration": 120, "memory": 1024 }
  },
  "crons": [
    {
      "path": "/api/full-auto-cron",
      "schedule": "0 0 * * *"
    }
  ]
}
