{
  "manifest_version": 3,
  "name": "Eden Crawl v2",
  "version": "3.1.1",
  "description": "에덴 전용 v3.1.1 — Threads 쓰레드(1/N 자동 이어붙임, handle 파싱 견고화) · LinkedIn · 아이보스 · X 인기글 수집 + 웹앱 연동",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://www.threads.com/*",
    "https://www.linkedin.com/*",
    "https://*.vercel.app/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://generativelanguage.googleapis.com/*",
    "https://www.i-boss.co.kr/*",
    "https://cdn.ibos.kr/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://wing.coupang.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Eden Crawl"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["content_webapp.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://wing.coupang.com/*"],
      "js": ["content_wing.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://wing.coupang.com/*"],
      "js": ["content_wing_bridge.js"],
      "run_at": "document_start"
    }
  ]
}
